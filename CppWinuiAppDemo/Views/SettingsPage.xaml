<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CppWinuiAppDemo.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CppWinuiAppDemo.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,Auto,Auto,*"
          ColumnDefinitions="Auto,*"
          RowSpacing="10"
          ColumnSpacing="10"
          Padding="20">
        <TextBlock Text="Settings"
                   Grid.Row="0"
                   FontSize="24" />
        <Button Content="Open"
                Grid.Row="0"
                Grid.Column="1"
                Command="{x:Bind ViewModel.OpenExplorerCommand}" />

        <TextBlock Text="Clock format:"
                   Grid.Row="1"
                   Grid.Column="0"
                   VerticalAlignment="Center" />
        <ComboBox x:Name="timeFormatComboBox"
                  Grid.Row="1"
                  Grid.Column="1"
                  SelectedItem="{x:Bind ViewModel.SelectedTimeFormat, Mode=OneWay}">
            <x:String>longtime</x:String>
            <x:String>shorttime</x:String>
        </ComboBox>

        <Button Content="Save"
                Grid.Row="2"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Right"
                Command="{x:Bind ViewModel.SaveSettingsCommand}" />
    </Grid>
</Page>
